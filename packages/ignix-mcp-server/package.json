{
  "name": "@mindfiredigital/ignix-mcp-server",
  "version": "1.0.0",
  "description": "Official MCP Server for Ignix UI — works in Cursor, Claude, Copilot, Windsurf",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ignix-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "mcp.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
